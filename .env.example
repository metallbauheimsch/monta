# Lokale Entwicklung – dieselben Werte wie in Vercel (Environment Variables).
# Datei als `.env.local` speichern (steht in .gitignore, niemals committen).
# Danach Dev-Server neu starten: npm run dev
#
# Ohne diese Variablen verbindet MONTA sich nicht mit Supabase und zeigt
# keine Live-Projektdaten.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
